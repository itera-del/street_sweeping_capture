name: "cnn_chinese_net"
layer {
  name: "data"
  type: "Input"
  top: "data"
  input_param {
    shape {
      dim: 1
      dim: 1
      dim: 64
      dim: 256
    }
  }
}
layer {
  name: "Convolution0"
  type: "Convolution"
  bottom: "data"
  top: "Convolution0"
  param {
    lr_mult: 1.0
  }
  convolution_param {
    num_output: 16
    bias_term: false
    pad: 1
    kernel_size: 3
    stride: 2
    weight_filler {
      type: "msra"
    }
  }
}
layer {
  name: "BatchNorm0"
  type: "BatchNorm"
  bottom: "Convolution0"
  top: "BatchNorm0"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "Scale0"
  type: "Scale"
  bottom: "BatchNorm0"
  top: "BatchNorm0"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "ReLU0"
  type: "ReLU"
  bottom: "BatchNorm0"
  top: "BatchNorm0"
}


layer {
  name: "Convolution1"
  type: "Convolution"
  bottom: "BatchNorm0"
  top: "Convolution1"
  param {
    lr_mult: 1.0
  }
  convolution_param {
    num_output: 32
    bias_term: false
    pad: 1
    kernel_size: 3
    stride: 2
    weight_filler {
      type: "msra"
    }
  }
}
layer {
  name: "BatchNorm1"
  type: "BatchNorm"
  bottom: "Convolution1"
  top: "BatchNorm1"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "Scale1"
  type: "Scale"
  bottom: "BatchNorm1"
  top: "BatchNorm1"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "ReLU1"
  type: "ReLU"
  bottom: "BatchNorm1"
  top: "BatchNorm1"
}




#1_layer: stage0_1
layer {
  name: "1_layer_0_Convolution1/dw"
  type: "Convolution"
  bottom: "BatchNorm1"
  top: "1_layer_0_Convolution1/dw"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 32
    bias_term: false
    pad: 1
    kernel_size: 3
    stride:1
    group: 32
    #engine: CAFFE
    weight_filler {
      type: "msra"
    }
  }
}

layer {
  name: "1_layer_0_BatchNorm1"
  type: "BatchNorm"
  bottom: "1_layer_0_Convolution1/dw"
  top: "1_layer_0_BatchNorm1"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "1_layer_0_Scale1"
  type: "Scale"
  bottom: "1_layer_0_BatchNorm1"
  top: "1_layer_0_BatchNorm1"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "1_layer_0_ReLU1"
  type: "ReLU"
  bottom: "1_layer_0_BatchNorm1"
  top: "1_layer_0_BatchNorm1"
}

#1_layer: stage0_2
layer {
  name: "1_layer_0_Convolution2"
  type: "Convolution"
  bottom: "1_layer_0_BatchNorm1"
  top: "1_layer_0_Convolution2"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 32
    bias_term: false
    kernel_size: 1
    stride: 1
    weight_filler {
      type: "msra"
    }
  }
}
layer {
  name: "1_layer_0_BatchNorm2"
  type: "BatchNorm"
  bottom: "1_layer_0_Convolution2"
  top: "1_layer_0_BatchNorm2"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "1_layer_0_Scale2"
  type: "Scale"
  bottom: "1_layer_0_BatchNorm2"
  top: "1_layer_0_BatchNorm2"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "Eltwise1"
  type: "Eltwise"
  bottom: "BatchNorm1"
  bottom: "1_layer_0_BatchNorm2"
  top: "Eltwise1"
  eltwise_param {
    operation: SUM
  }
}


#2_layer: stage1_1
layer {
  name: "2_layer_0_Convolution1/dw"
  type: "Convolution"
  bottom: "Eltwise1"
  top: "2_layer_0_Convolution1/dw"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 32
    bias_term: false
    pad: 1
    kernel_size: 3
    stride: 2
    group: 32
    #engine: CAFFE
    weight_filler {
      type: "msra"
    }
  }
}

layer {
  name: "2_layer_0_BatchNorm1"
  type: "BatchNorm"
  bottom: "2_layer_0_Convolution1/dw"
  top: "2_layer_0_BatchNorm1"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "2_layer_0_Scale1"
  type: "Scale"
  bottom: "2_layer_0_BatchNorm1"
  top: "2_layer_0_BatchNorm1"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "2_layer_0_ReLU1"
  type: "ReLU"
  bottom: "2_layer_0_BatchNorm1"
  top: "2_layer_0_BatchNorm1"
}

layer {
  name: "2_layer_0_Convolution2"
  type: "Convolution"
  bottom: "2_layer_0_BatchNorm1"
  top: "2_layer_0_Convolution2"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 32
    bias_term: false
    kernel_size: 1
    stride: 1
    weight_filler {
      type: "msra"
    }
  }
}
layer {
  name: "2_layer_0_BatchNorm2"
  type: "BatchNorm"
  bottom: "2_layer_0_Convolution2"
  top: "2_layer_0_BatchNorm2"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "2_layer_0_Scale2"
  type: "Scale"
  bottom: "2_layer_0_BatchNorm2"
  top: "2_layer_0_BatchNorm2"
  scale_param {
    bias_term: true
  }
}

#2_layer: stage1_1
layer {
  name: "2_layer_1_Convolution1/dw"
  type: "Convolution"
  bottom: "2_layer_0_BatchNorm2"
  top: "2_layer_1_Convolution1/dw"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 32
    bias_term: false
    pad: 1
    kernel_size: 3
    stride: 1
    group: 32
    #engine: CAFFE
    weight_filler {
      type: "msra"
    }
  }
}

layer {
  name: "2_layer_1_BatchNorm1"
  type: "BatchNorm"
  bottom: "2_layer_1_Convolution1/dw"
  top: "2_layer_1_BatchNorm1"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "2_layer_1_Scale1"
  type: "Scale"
  bottom: "2_layer_1_BatchNorm1"
  top: "2_layer_1_BatchNorm1"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "2_layer_1_ReLU1"
  type: "ReLU"
  bottom: "2_layer_1_BatchNorm1"
  top: "2_layer_1_BatchNorm1"
}

#2_layer: stage0_2
layer {
  name: "2_layer_1_Convolution2"
  type: "Convolution"
  bottom: "2_layer_1_BatchNorm1"
  top: "2_layer_1_Convolution2"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 32
    bias_term: false
    kernel_size: 1
    stride: 1
    weight_filler {
      type: "msra"
    }
  }
}
layer {
  name: "2_layer_1_BatchNorm2"
  type: "BatchNorm"
  bottom: "2_layer_1_Convolution2"
  top: "2_layer_1_BatchNorm2"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "2_layer_1_Scale2"
  type: "Scale"
  bottom: "2_layer_1_BatchNorm2"
  top: "2_layer_1_BatchNorm2"
  scale_param {
    bias_term: true
  }
}

layer {
  name: "Eltwise2"
  type: "Eltwise"
  bottom: "2_layer_0_BatchNorm2"
  bottom: "2_layer_1_BatchNorm2"
  top: "Eltwise2"
  eltwise_param {
    operation: SUM
  }
}



##3_layer: stage0_1
layer {
  name: "3_layer_0_Convolution1"
  type: "Convolution"
  bottom: "Eltwise2"
  top: "3_layer_0_Convolution1"
  param {
