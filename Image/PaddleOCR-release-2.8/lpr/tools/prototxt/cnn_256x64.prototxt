  }
}

layer {
  name: "Eltwise3"
  type: "Eltwise"
  bottom: "3_layer_0_BatchNorm3"
  bottom: "3_layer_1_BatchNorm3"
  top: "Eltwise3"
  eltwise_param {
    operation: SUM
  }
}

###########################

