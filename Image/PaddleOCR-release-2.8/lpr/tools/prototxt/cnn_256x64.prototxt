  }
  convolution_param {
    num_output: 64
    bias_term: false
    kernel_size: 1
    stride: 1
    weight_filler {
      type: "msra"
    }
  }
}
layer {
  name: "3_layer_0_BatchNorm1"
  type: "BatchNorm"
  bottom: "3_layer_0_Convolution1"
  top: "3_layer_0_BatchNorm1"
  batch_norm_param {
