layer {
  name: "5_layer_0_Convolution2"
  type: "Convolution"
  bottom: "5_layer_0_BatchNorm1"
  top: "5_layer_0_Convolution2"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 256
    bias_term: false
    kernel_size: 1
    stride: 1
    weight_filler {
      type: "msra"
    }
  }
}
layer {
  name: "5_layer_0_BatchNorm2"
  type: "BatchNorm"
  bottom: "5_layer_0_Convolution2"
  top: "5_layer_0_BatchNorm2"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "5_layer_0_Scale2"
  type: "Scale"
  bottom: "5_layer_0_BatchNorm2"
  top: "5_layer_0_BatchNorm2"
  scale_param {
    bias_term: true
  }
}




#5_layer: stage1_1
layer {
  name: "5_layer_1_Convolution1/dw"
  type: "Convolution"
  bottom: "5_layer_0_BatchNorm2"
  top: "5_layer_1_Convolution1/dw"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 256
    bias_term: false
    pad: 1
    kernel_size: 3
    stride: 1
    group: 256
    #engine: CAFFE
    weight_filler {
      type: "msra"
    }
  }
}

layer {
  name: "5_layer_1_BatchNorm1"
  type: "BatchNorm"
  bottom: "5_layer_1_Convolution1/dw"
  top: "5_layer_1_BatchNorm1"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "5_layer_1_Scale1"
  type: "Scale"
  bottom: "5_layer_1_BatchNorm1"
  top: "5_layer_1_BatchNorm1"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "5_layer_1_ReLU1"
  type: "ReLU"
  bottom: "5_layer_1_BatchNorm1"
  top: "5_layer_1_BatchNorm1"
}

#5_layer: stage0_2
layer {
  name: "5_layer_1_Convolution2"
  type: "Convolution"
  bottom: "5_layer_1_BatchNorm1"
  top: "5_layer_1_Convolution2"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 256
    bias_term: false
    kernel_size: 1
    stride: 1
    weight_filler {
      type: "msra"
    }
  }
}
layer {
  name: "5_layer_1_BatchNorm2"
  type: "BatchNorm"
  bottom: "5_layer_1_Convolution2"
  top: "5_layer_1_BatchNorm2"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "5_layer_1_Scale2"
  type: "Scale"
  bottom: "5_layer_1_BatchNorm2"
  top: "5_layer_1_BatchNorm2"
  scale_param {
    bias_term: true
  }
}

layer {
  name: "Eltwise5"
  type: "Eltwise"
  bottom: "5_layer_0_BatchNorm2"
  bottom: "5_layer_1_BatchNorm2"
  top: "Eltwise5"
  eltwise_param {
    operation: SUM
  }
}
##############################
layer {
  name: "cnn_layer"
  type: "Convolution"
  bottom: "Eltwise5"
  top: "cnn_layer"
  param {
    lr_mult: 1
  }
  convolution_param {
    num_output: 69
    bias_term: true
    kernel_size: 1
    stride: 1
    weight_filler {
      type: "msra"
    }
  }
}
layer {
    name: "reshape"
    type: "Reshape"
    bottom: "cnn_layer"
    top: "reshape"
    reshape_param {
        shape {
        #n*c*(w*h)
            dim: 0
            dim: 69
            dim: 1
            dim: 16
        }
    }
}
####################################
layer {
  name: "probs"
  type: "Softmax"
  bottom: "reshape"
  top: "probs"
  softmax_param {
    axis: 1
  }
}




